// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    USER
    ADMIN
}

enum Gender {
    WOMAN
    MAN
}

enum LoanStatus {
    IN_PROGRESS
    FINISHED
}

enum InstallmentType {
    NORMAL
    CUSTOM
}

enum AchievementType {
    FASTEST_PAYER
    GOOD_KARMA
}

model UserAchievement {
    id        Int             @id @default(autoincrement())
    userId    Int
    user      User            @relation("UserAchievements", fields: [userId], references: [id])
    type      AchievementType
    title     String?
    metadata  Json?
    createdAt DateTime        @default(now())
}

model User {
    id            Int           @id @default(autoincrement())
    email         String        @unique()
    password      String
    firstName     String
    lastName      String
    gender        Gender
    cardNumber    String?
    accountNumber String?
    avatar        String?
    profileColor  String?       @default("#3B82F6")
    createdAt     DateTime      @default(now())
    lastLoginAt   DateTime?
    deletedAt     DateTime?
    role          Role          @default(USER)
    telegramId       BigInt?       @unique
    telegramUsername String?
    preferences      Json?
    accounts      Account[]
    Installment   Installment[]
    paymentRequests         PaymentRequest[] @relation("UserPaymentRequests")
    reviewedPaymentRequests PaymentRequest[] @relation("ReviewedPaymentRequests")
    loanQueueAdjustments    LoanQueueEntry[] @relation("LoanQueueAdjustments")
    achievements            UserAchievement[] @relation("UserAchievements")
}

model TelegramGroupMember {
    id         Int      @id @default(autoincrement())
    telegramId BigInt   @unique
    chatId     BigInt
    username   String?
    firstName  String?
    lastName   String?
    isBot      Boolean  @default(false)
    status     String?
    lastSeenAt DateTime @default(now())
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
}

model Account {
    id                Int           @id @default(autoincrement())
    code              String
    name              String?
    installmentFactor Int
    balance           Decimal       @db.Decimal(20, 2)
    createdAt         DateTime      @default(now())
    updatedAt         DateTime      @default(now())
    openedAt          DateTime?
    deletedAt         DateTime?
    user              User          @relation(fields: [userId], references: [id])
    userId            Int
    loans             Loan[]
    installments      Installment[]
    loanQueueEntry    LoanQueueEntry?
}

model InstallmentAmount {
    id           Int           @id @default(autoincrement())
    amount       Decimal       @db.Decimal(20, 2)
    createdAt    DateTime      @default(now())
    deprecatedAt DateTime?
    installments Installment[]
}

model Config {
    id          Int     @id @default(autoincrement())
    name        String  @unique()
    label       String?
    description String? @db.Text
    value       Json
}

model Loan {
    id           Int        @id @default(autoincrement())
    description  String?    @db.Text
    account      Account?   @relation(fields: [accountId], references: [id])
    accountId    Int?
    amount       Decimal    @db.Decimal(20, 2)
    paymentCount Int
    status       LoanStatus @default(IN_PROGRESS)
    createdAt    DateTime   @default(now())
    startedAt    DateTime?
    finishedAt   DateTime?
    payments     Payment[]
}

model Payment {
    id               Int             @id @default(autoincrement())
    amount           Decimal         @db.Decimal(20, 2)
    dueDate          DateTime
    paidAt           DateTime?
    loan             Loan?           @relation(fields: [loanId], references: [id])
    loanId           Int?
    paymentRequestId Int?
    paymentRequest   PaymentRequest? @relation(fields: [paymentRequestId], references: [id])
}

model Installment {
    id                  Int                @id @default(autoincrement())
    installmentAmount   InstallmentAmount? @relation(fields: [installmentAmountId], references: [id])
    installmentAmountId Int?
    account             Account?           @relation(fields: [accountId], references: [id])
    accountId           Int?
    amount              Decimal            @db.Decimal(20, 2)
    type                InstallmentType    @default(NORMAL)
    approvedBy          User?              @relation(fields: [approvedById], references: [id])
    approvedById        Int?
    createdAt           DateTime           @default(now())
    dueDate             DateTime           @default(now())
    paidAt              DateTime?
    approvedAt          DateTime?
    paymentRequestId    Int?
    paymentRequest      PaymentRequest?    @relation(fields: [paymentRequestId], references: [id])
}

enum PaymentRequestStatus {
    PENDING
    APPROVED
    REJECTED
}

model PaymentRequest {
    id            Int                  @id @default(autoincrement())
    userId        Int
    user          User                 @relation("UserPaymentRequests", fields: [userId], references: [id])
    amount        Decimal              @db.Decimal(20, 2)
    receiptFileId String?              // Telegram photo file_id (stored on Telegram servers)
    status        PaymentRequestStatus @default(PENDING)
    messageId     Int?                 // Telegram message ID for replying later
    adminReplyId  Int?                 // ID of the admin's reply in Telegram
    reviewedById  Int?
    reviewedBy    User?                @relation("ReviewedPaymentRequests", fields: [reviewedById], references: [id])
    createdAt     DateTime             @default(now())
    updatedAt     DateTime             @updatedAt
    
    installments  Installment[]
    payments      Payment[]
}

model LoanQueueEntry {
    id                 Int      @id @default(autoincrement())
    accountId          Int      @unique
    account            Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
    position           Int
    completedLoanCount Int
    joinedAt           DateTime @default(now())
    isManualPosition   Boolean  @default(false)
    manualNote         String?  @db.Text
    adjustedById       Int?
    adjustedBy         User?    @relation("LoanQueueAdjustments", fields: [adjustedById], references: [id])
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt

    @@unique([position])
    @@index([position])
}
