# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://user:password@localhost:5432/da_name?schema=public"

AUTH_SECRET="my-secret"

# Telegram Mini App (user panel)
TELEGRAM_BOT_TOKEN=""
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""
# Group chat ID (negative number for supergroups) — forward a group message to @userinfobot or @RawDataBot
TELEGRAM_GROUP_CHAT_ID=""
# Forum topic ID (integer, optional) — where payment screenshots should be sent
TELEGRAM_PAYMENTS_TOPIC_ID=""
# Webhook secret: letters, numbers, underscore, hyphen only (no &, spaces)
TELEGRAM_WEBHOOK_SECRET=""

# Public app URL (ngrok/production) — required for Telegram webhook + dev login via tunnel
NEXT_PUBLIC_APP_URL="https://your-subdomain.ngrok-free.app"
# Optional: extra dev hostnames for Next.js allowedDevOrigins (comma-separated)
# DEV_ALLOWED_ORIGINS="your-subdomain.ngrok-free.app"

CRON_SECRET=""